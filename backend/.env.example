NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Database
DYNAMODB_USERS_TABLE=compliquest-users-dev
DYNAMODB_ORGANIZATIONS_TABLE=compliquest-organizations-dev
DYNAMODB_PROJECTS_TABLE=compliquest-projects-dev
DYNAMODB_CONTROLS_TABLE=compliquest-controls-dev
DYNAMODB_ACHIEVEMENTS_TABLE=compliquest-achievements-dev
DYNAMODB_ALERTS_TABLE=compliquest-alerts-dev

# S3
S3_ASSETS_BUCKET=compliquest-assets-dev
S3_EVIDENCE_BUCKET=compliquest-evidence-dev

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRY=24h

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-v2
